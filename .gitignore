# Ignore large raw image files and intermediate tracks
*.czi
*.csv
*.jpg
*.tif
*.tiff
*.xml
*.pptx
*.ppt
*.key


# Ignore python caches and virtual environments
__pycache__/
*.py[cod]
*$py.class
.venv/
.env

# Whole `data/` tree (datasets, plots, CZIs, CSVs). `data/` ignores the directory and everything
# under it (prefer this over `data/*`, which only matches one path level on some Git versions).
# Root-level patterns like `0714*` / `*HF*` are unnecessary once `data/` exists and are risky
# (`*HF*` can match unrelated names).
/data/

# Analysis run outputs (timestamped folders; configs + CSV/PNG/PDF artifacts)
/output/

# Local scratch file (ignored only while untracked). If Git still tracks it: `git rm --cached ToDo.txt`
ToDo.txt
/.data/